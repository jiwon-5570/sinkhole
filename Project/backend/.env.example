# Backend env
SINKHOLE_ENV=development
SINKHOLE_HOST=127.0.0.1
SINKHOLE_PORT=5000
SINKHOLE_RELOAD=1
SINKHOLE_APPLY_SCHEMA_ON_START=1
SINKHOLE_SEED_DEMO=0
SINKHOLE_ANALYZE_ON_START=1

# Enable in production. If enabled, both username and password are required.
SINKHOLE_ENABLE_BASIC_AUTH=0
SINKHOLE_BASIC_AUTH_USERNAME=admin
SINKHOLE_BASIC_AUTH_PASSWORD=change-this-password

# Only expose a browser-restricted Google Maps key to the frontend.
SINKHOLE_EXPOSE_GOOGLE_MAPS_KEY=0

# Outbound request timeouts
SINKHOLE_EXTERNAL_TIMEOUT_SECONDS=15
SINKHOLE_GEMINI_TIMEOUT_SECONDS=30
SINKHOLE_PUBLIC_DATA_TIMEOUT_SECONDS=20
SINKHOLE_PUBLIC_DATA_AUTO_COLLECT=1
SINKHOLE_PUBLIC_DATA_COLLECT_ON_START=1
SINKHOLE_PUBLIC_DATA_INTERVAL_SECONDS=3600
SINKHOLE_PUBLIC_DATA_ROWS_PER_PAGE=100
SINKHOLE_PUBLIC_DATA_MAX_PAGES=3
SINKHOLE_SAFEMAP_OLD_BUILDING_ENABLED=1
SINKHOLE_SAFEMAP_OLD_BUILDING_API_URL=http://safemap.go.kr/openapi2/IF_0002
SINKHOLE_SAFEMAP_OLD_BUILDING_ROWS_PER_PAGE=100
SINKHOLE_SAFEMAP_OLD_BUILDING_MAX_PAGES=3
SINKHOLE_PUBLIC_DATA_ACCIDENT_LOOKBACK_DAYS=3650
SINKHOLE_PUBLIC_DATA_WEATHER_LOOKBACK_DAYS=14
SINKHOLE_PUBLIC_DATA_CONSTRUCTION_LOOKBACK_DAYS=1095
SINKHOLE_LOCAL_CONSTRUCTION_FILE_IMPORT_ENABLED=1
SINKHOLE_LOCAL_CONSTRUCTION_FILE_IMPORT_INTERVAL_SECONDS=30
SINKHOLE_LOCAL_CONSTRUCTION_FILE_DIR=data/raw/public/seoul_road_excavation
SINKHOLE_MONITORING_POINTS_MAX_COUNT=10
SINKHOLE_MONITORING_POINTS_REFRESH_SECONDS=900
SINKHOLE_MOLIT_BOREHOLE_API_ENABLED=1
SINKHOLE_MOLIT_BOREHOLE_API_URL=https://api.odcloud.kr/api/15069365/v1/uddi:e3857d80-b97e-4693-84d5-f2b4f37959f0
SINKHOLE_MOLIT_BOREHOLE_ROWS_PER_PAGE=1000
SINKHOLE_MOLIT_BOREHOLE_MAX_PAGES=500
SINKHOLE_MOLIT_BOREHOLE_REFRESH_DAYS=30
SINKHOLE_MOLIT_BOREHOLE_MIN_CACHED_ROWS=300000
SINKHOLE_MOLIT_BOREHOLE_COORD_CRS=EPSG:5186
SINKHOLE_MOLIT_AGGREGATE_GEOPHYSICS_ENABLED=1
SINKHOLE_MOLIT_AGGREGATE_GEOPHYSICS_URL=https://api.odcloud.kr/api/15135630/v1/uddi:a19a4b57-3523-4570-ac2e-926a0a114978
SINKHOLE_MOLIT_AGGREGATE_GEOPHYSICS_ROWS_PER_PAGE=1000
SINKHOLE_MOLIT_AGGREGATE_GEOPHYSICS_MAX_PAGES=1
SINKHOLE_KALIS_PUBLIC_FACILITY_SAFETY_URL=http://apis.data.go.kr/B552016/PublicFacilSafetyMngService/getPublicFacilSafetyMngList
SINKHOLE_KALIS_PUBLIC_FACILITY_DIAGNOSIS_URL=http://apis.data.go.kr/B552016/PublicFacilDignService/getArDignList
SINKHOLE_KALIS_OLD_FACILITY_URL=http://apis.data.go.kr/B552016/OldFacilService/getFacil30YearsOldList
SINKHOLE_KALIS_FACILITY_ACCIDENT_URL=http://apis.data.go.kr/B552016/FacilAccidentService/getFacilAccidentList
SINKHOLE_UNDERGROUND_SAFETY_INFO_URL=http://apis.data.go.kr/1613000/undergroundsafetyinfo01/getImpatEvalutionList01
SINKHOLE_GROUND_SUBSIDENCE_ACCIDENT_URL=http://apis.data.go.kr/1613000/undergroundsafetyinfo01/getSubsidenceList01
SINKHOLE_KMA_ASOS_HOURLY_URL=http://apis.data.go.kr/1360000/AsosHourlyInfoService/getWthrDataList
SINKHOLE_KMA_ASOS_STATION_IDS=108
SINKHOLE_KMA_ASOS_TARGET_SIGUNGUS=강남구,송파구,강동구,강서구,영등포구,서초구,성동구,마포구,용산구,구로구
SINKHOLE_BUILDING_PERMIT_URL=http://apis.data.go.kr/1613000/ArchPmsHubService/getApBasisOulnInfo

# Optional
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash
GOOGLE_MAPS_API_KEY=your_key_here
PUBLIC_DATA_API_KEY=your_public_data_api_key_here
SEOUL_OPEN_DATA_API_KEY=your_seoul_open_data_key_here
SINKHOLE_SEOUL_OPEN_DATA_ENABLED=1
SINKHOLE_SEOUL_OPEN_DATA_BASE_URL=http://openapi.seoul.go.kr:8088
SINKHOLE_SEOUL_OPEN_DATA_ROWS_PER_PAGE=1000
SINKHOLE_SEOUL_OPEN_DATA_MAX_PAGES=3
# Set these to the exact Open API service names shown on each Seoul Open Data dataset page.
SINKHOLE_SEOUL_GROUNDWATER_OBSERVATION_SERVICE=VTsSec
SINKHOLE_SEOUL_RAINFALL_SERVICE=ListRainfallService
SINKHOLE_SEOUL_SEWER_LEVEL_SERVICE=DrainpipeMonitoringInfo
SINKHOLE_SEOUL_ROAD_EXCAVATION_SERVICE=TnCnwInfoView
# SafeMap old-building API normally uses a 생활안전지도 service key.
# If omitted, PUBLIC_DATA_API_KEY is used as a fallback.
SAFEMAP_API_KEY=your_safemap_api_key_here
